#!/usr/bin/env python3
import json
import subprocess
from pathlib import Path


HISTORY_FILE = Path.home() / ".local/share/i3-clipboard/history.json"


def load_history():
    try:
        return json.loads(HISTORY_FILE.read_text())
    except Exception:
        return []


def save_history(items):
    HISTORY_FILE.parent.mkdir(parents=True, exist_ok=True)
    HISTORY_FILE.write_text(json.dumps(items, ensure_ascii=False, indent=2))


def label_for(index, text):
    one_line = " ".join(text.replace("\n", " ").split())
    if len(one_line) > 140:
        one_line = one_line[:137] + "..."
    return f"{index + 1:02d}  {one_line}"


def copy_to_clipboard(text):
    subprocess.run(
        ["xclip", "-selection", "clipboard"],
        input=text,
        text=True,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )


def main():
    items = load_history()
    if not items:
        subprocess.run(["rofi", "-e", "Clipboard history is empty"])
        return 0

    labels = [label_for(index, item.get("text", "")) for index, item in enumerate(items)]
    rofi = subprocess.run(
        [
            "rofi",
            "-dmenu",
            "-i",
            "-p",
            "clipboard",
            "-mesg",
            "Enter: copy | Alt+Enter: delete item | Ctrl+Delete: clear all",
            "-kb-custom-1",
            "Alt+Return",
            "-kb-custom-2",
            "Control+Delete",
        ],
        input="\n".join(labels),
        text=True,
        stdout=subprocess.PIPE,
    )

    selected = rofi.stdout.rstrip("\n")
    if not selected:
        return 0

    try:
        index = labels.index(selected)
    except ValueError:
        return 0

    if rofi.returncode == 10:
        del items[index]
        save_history(items)
    elif rofi.returncode == 11:
        save_history([])
    else:
        copy_to_clipboard(items[index].get("text", ""))

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
