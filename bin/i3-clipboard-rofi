#!/usr/bin/env python3
import json
import subprocess
from pathlib import Path


HISTORY_FILE = Path.home() / ".local/share/i3-clipboard/history.json"


def load_history():
    try:
        return json.loads(HISTORY_FILE.read_text())
    except Exception:
        return []


def save_history(items):
    HISTORY_FILE.parent.mkdir(parents=True, exist_ok=True)
    HISTORY_FILE.write_text(json.dumps(items, ensure_ascii=False, indent=2))
    cleanup_images(items)


def cleanup_images(items):
    used = {
        Path(item["path"]).name
        for item in items
        if item.get("type") == "image" and item.get("path")
    }
    images_dir = HISTORY_FILE.parent / "images"
    if not images_dir.exists():
        return
    for path in images_dir.glob("*.png"):
        if path.name not in used:
            try:
                path.unlink()
            except OSError:
                pass


def label_for(index, item):
    item_type = item.get("type", "text")
    if item_type == "image":
        width = item.get("width") or "?"
        height = item.get("height") or "?"
        size = item.get("size") or 0
        size_kb = max(1, round(size / 1024))
        return f"{index + 1:02d}  [imagem PNG {width}x{height} {size_kb}KB]"

    text = item.get("text", "")
    one_line = " ".join(text.replace("\n", " ").split())
    if len(one_line) > 140:
        one_line = one_line[:137] + "..."
    return f"{index + 1:02d}  {one_line}"


def copy_to_clipboard(text):
    subprocess.run(
        ["xclip", "-selection", "clipboard"],
        input=text,
        text=True,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )


def copy_image_to_clipboard(path):
    image_path = Path(path)
    if not image_path.exists():
        subprocess.run(["rofi", "-e", "Imagem nao encontrada no historico"])
        return

    with image_path.open("rb") as image:
        subprocess.run(
            ["xclip", "-selection", "clipboard", "-t", "image/png"],
            stdin=image,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )


def main():
    items = load_history()
    if not items:
        subprocess.run(["rofi", "-e", "Clipboard history is empty"])
        return 0

    labels = [label_for(index, item) for index, item in enumerate(items)]
    rofi = subprocess.run(
        [
            "rofi",
            "-dmenu",
            "-i",
            "-p",
            "clipboard",
            "-mesg",
            "Enter: copy image/text | Alt+Enter: delete item | Ctrl+Delete: clear all",
            "-kb-custom-1",
            "Alt+Return",
            "-kb-custom-2",
            "Control+Delete",
        ],
        input="\n".join(labels),
        text=True,
        stdout=subprocess.PIPE,
    )

    selected = rofi.stdout.rstrip("\n")
    if not selected:
        return 0

    try:
        index = labels.index(selected)
    except ValueError:
        return 0

    if rofi.returncode == 10:
        del items[index]
        save_history(items)
    elif rofi.returncode == 11:
        save_history([])
    else:
        item = items[index]
        if item.get("type") == "image":
            copy_image_to_clipboard(item.get("path", ""))
        else:
            copy_to_clipboard(item.get("text", ""))

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
